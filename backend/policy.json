{
  "policy_name": "pab_ai_triage_v1",
  "scope": {
    "population": "elderly_residents_living_alone_in_rental_flats",
    "input_mode": "pab_triggered_audio",
    "operation_hours": "24x7",
    "human_in_loop": true,
    "low_confidence_default": "escalate"
  },
  "red_flag_audio_signals": [
    "fall_impact_sound",
    "distress_vocalisation",
    "gasping_or_laboured_breathing",
    "extended_silence_after_trigger"
  ],
  "urgency_buckets": [
    "life_threatening",
    "emergency",
    "requires_review",
    "minor_emergency",
    "non_emergency"
  ],
  "queue_order": [
    "life_threatening",
    "emergency",
    "requires_review",
    "minor_emergency",
    "non_emergency"
  ],
  "target_wait_seconds": {
    "life_threatening": 0,
    "emergency": 60,
    "requires_review": 180,
    "minor_emergency": 600,
    "non_emergency": 1800
  },
  "mandatory_actions_by_bucket": {
    "life_threatening": [
      "call_patient_now",
      "call_995",
      "inform_emergency_contact"
    ],
    "emergency": [
      "call_patient_now",
      "inform_emergency_contact"
    ],
    "requires_review": [
      "call_patient_now",
      "inform_emergency_contact"
    ],
    "minor_emergency": [
      "call_patient_now"
    ],
    "non_emergency": [
      "call_patient_now"
    ]
  },
  "discretionary_actions": [
    "call_995",
    "call_999",
    "call_private_ambulance_1777",
    "call_ed_by_private_transport",
    "call_sgsecure_volunteers",
    "notify_lift_lobby",
    "inform_emergency_contact"
  ],
  "allowed_actions": [
    "call_patient_now",
    "inform_emergency_contact",
    "call_sgsecure_volunteers",
    "call_995",
    "call_private_ambulance_1777",
    "call_ed_by_private_transport",
    "call_999",
    "notify_lift_lobby"
  ]
}